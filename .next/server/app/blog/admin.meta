{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/admin/layout,_N_T_/blog/admin/page,_N_T_/blog/admin"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/blog/admin/__PAGE__",
    "/blog/admin",
    "/blog",
    "/_index",
    "/_head"
  ]
}