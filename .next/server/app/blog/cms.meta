{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/cms/layout,_N_T_/blog/cms/page,_N_T_/blog/cms"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/blog/cms/__PAGE__",
    "/blog/cms",
    "/blog",
    "/_index",
    "/_head"
  ]
}